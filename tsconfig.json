// TypeScript configuration for Supabase Edge Functions + Deno
// (source: D6, R7 — Supabase CLI + Deno EF workflow; no frontend)
{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["supabase/functions/**/*.ts"],
  "exclude": ["node_modules"]
}